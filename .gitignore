# ─── Dataset (troppo grandi per git) ──────────────────────────────────────────
data/raw/*
data/cleaned/*
data/samples/*
# Mantieni le cartelle vuote
!data/raw/.gitkeep
!data/cleaned/.gitkeep
!data/samples/.gitkeep

# ─── Parquet (rigenerabili da cleaning + convert_to_parquet) ──────────────────
*.parquet

# ─── Consegna e documenti privati ─────────────────────────────────────────────
Descrizione Progetto.pdf
*.zip

# ─── Relazione LaTeX — sorgente e artefatti di compilazione ───────────────────
relazione.tex
relazione.pdf
*.aux
*.toc
*.out
*.fls
*.fdb_latexmk
*.synctex.gz
*.bbl
*.blg

# ─── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/

# ─── Virtual environments ─────────────────────────────────────────────────────
.venv/
venv/
env/
.env/
ENV/

# ─── Jupyter ──────────────────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb_checkpoints

# ─── Spark / Hadoop / Hive ────────────────────────────────────────────────────
spark-warehouse/
metastore_db/
derby.log
logs/
*.log

# ─── AWS ──────────────────────────────────────────────────────────────────────
aws/.cluster_id
.aws/

# ─── IDE / Editor ─────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ─── macOS ────────────────────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride
Icon
._*
.Spotlight-V100
.Trashes

# ─── File temporanei ──────────────────────────────────────────────────────────
*.tmp
*.temp
